{
  "type": "module",
  "sideEffects": false,
  "name": "@hoangvvo/llm-agent",
  "version": "0.3.0",
  "description": "The agent library to build LLM applications that work with any LLM providers.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "c8 --all --include='src/**/*.ts' --exclude='**/*.test.ts' --exclude='src/**/index.ts' --exclude='src/**/types.ts' --exclude='src/toolkit.ts' --reporter=text --reporter=cobertura node --test \"**/*.test.ts\""
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoangvvo/llm-sdk.git",
    "directory": "agent-js"
  },
  "author": "Hoang Vo (https://www.hoangvvo.com)",
  "bugs": {
    "url": "https://github.com/hoangvvo/llm-sdk/issues"
  },
  "homepage": "https://github.com/hoangvvo/llm-sdk",
  "keywords": [
    "llm",
    "language model",
    "agent",
    "ai",
    "openai",
    "anthropic",
    "cohere",
    "mistral"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./typebox": "./dist/typebox/index.js",
    "./zod": "./dist/zod/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "dependencies": {
    "@hoangvvo/llm-sdk": ">=0.5.0 <1.0",
    "@opentelemetry/api": "^1.9.1"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.3.6",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "typebox": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "zod-to-json-schema": {
      "optional": true
    }
  }
}
