        },
        "model_name": {
          "default": "mistral-moderation-2603",
          "description": "Override model name. Should be omitted in general.",
          "title": "Model Name",
          "type": "string"
        }
      },
      "title": "ModerationLLMV2Config",
      "type": "object"
    },
