    "ModerationLLMV1CategoryThresholds": {
      "properties": {
        "dangerous_and_criminal_content": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Dangerous And Criminal Content"
        },
        "financial": {
