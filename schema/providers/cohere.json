          },
          "type": "array"
        },
        "message": {
          "$ref": "#/definitions/AssistantMessageResponse"
        },
        "usage": {
          "$ref": "#/definitions/Usage"
        }
      },
      "required": [
        "id",
        "finish_reason",
        "message"
      ]
    },
